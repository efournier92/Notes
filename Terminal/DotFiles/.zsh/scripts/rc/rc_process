#!/bin/bash

#----------------
# Name          : rc_process
# Description   : Processes raw WAV voice memos as smaller MP3 files for long-term archival storage.
# Author        : E Fournier
# Dependencies  : ffmpeg
# Example Usage : ./rc_process $in_dir $out_dir [debugger]
#----------------

shopt -s extglob

IS_DEBUG=false

concat_dir() {
  local out_dir="$1"

  echo "$out_dir/.concat"
}

concat_file() {
  local date=$(parse_date "$1")
  local out_dir="$2"

  local dir=$(concat_dir "$out_dir")

  echo "$dir/$date.txt"
}

mp3_file() {
  local date="$1"
  local out_dir="$2"

  echo "$out_dir/$date.mp3"
}

is_valid_file() {
  local eval_file="$1"

  if [[ -f "$eval_file" ]]; then
    [[ "$eval_file" = *.WAV || "$eval_file" = *.wav ]] && [[ ! "$eval_file" =~ [@#\$%^\&*+] ]]
  else
    false
  fi
}

is_valid_file_name() {
  local eval_file="$1"

  local file_name="${eval_file##*/}"
  local file_name="${file_name%%.*}"

  if [[ "$file_name" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{4}_[0-9]{2}$ ]]; then
    [[ "$IS_DEBUG" = true ]] && echo "$file_name IS a valid file" >&2

    true
  else
    [[ "$IS_DEBUG" = true ]] && echo "$file_name is NOT a valid file" >&2

    false
  fi
}

parse_date() {
  local eval_file="$1"
  local file_name="${eval_file##*/}"
  local file_name="${file_name%%.*}"
  local file_name="${file_name%%_*}"

  echo "$file_name"
}

format_duration() {
  local total_seconds="$1"
  local hours=$((total_seconds / 3600))
  local minutes=$(((total_seconds % 3600) / 60))
  local seconds=$((total_seconds % 60))

  printf "%02d:%02d:%02d" "$hours" "$minutes" "$seconds"
}

get_formatted_duration() {
  local file="$1"

  local duration_seconds=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$file" | cut -d. -f1)
  local formatted_duration=$(format_duration "$duration_seconds")
  echo "$formatted_duration"
}

get_current_date_ym() {
  echo "$(date "+%Y-%m-")"
}

get_current_date_ym() {
  echo "$(date "+%Y-%m-")"
}

is_in_split_sequence() {
  local formatted_duration="$1"
  local duration_match=false
  local split_durations_list=("02:00:00" "01:59:59")

  for split_duration in "${split_durations_list[@]}"; do
    if [[ "$formatted_duration" == "$split_duration" ]]; then
      duration_match=true
      break
    fi
  done

  if $duration_match; then
    true
  else
    false
  fi
}

wait_for_ffmpeg_to_finish() {
  [[ "$IS_DEBUG" = true ]] && echo "Started waiting for FFmpeg to finish"

  local time_spent_waiting=0

  until [[ "$is_convert_complete" == true || "$time_spent_waiting" -gt 10000 ]]; do
    local seconds_to_wait=1
    sleep "$seconds_to_wait"
    [[ "$IS_DEBUG" = true ]] && echo "Waiting for FFmpeg: $time_spent_waiting seconds"
    local time_spent_waiting=$((time_spent_waiting + seconds_to_wait))
    local ffmpeg_windows=$(tmux list-windows | grep -i 'ffmpeg')
    if [[ "$ffmpeg_windows" == '' ]]; then
      [[ "$IS_DEBUG" = true ]] && echo "FFmpeg conversion complete"
      is_convert_complete=true
    fi
  done
}

convert_audio_files() {
  local in_dir="$1"
  local out_dir="$2"

  for file_to_convert in "$in_dir"/*; do
    [[ "$file_to_convert" = *.WAV ]] || continue

    if ! $(is_valid_file "$file_to_convert"); then
      [[ "$IS_DEBUG" = true ]] && echo "Skipping invalid file $file_to_convert"
      continue
    fi

    local date=$(parse_date "$file_to_convert")
    local mp3_file=$(mp3_file "$date" "$out_dir")
    local concat_file=$(concat_file "$date" "$out_dir")

    if [[ "$IS_DEBUG" = true ]]; then
      echo "------------"
      echo "CONVERTING WITH FFMPEG:"
      echo "  Convert File: $file_to_convert"
      echo "  Date: $date"
      echo "  MP3 File: $mp3_file"
      echo "  Concat File: $concat_file"
    fi

    if [[ "$file_to_convert" =~ "_00" ]]; then
      [[ "$IS_DEBUG" = true ]] && echo "  First File: "$file_to_convert""
      local file_to_write=$(concat_file "$date" "$out_dir")
      clean_concat_file "$file_to_write" "$out_dir" "$IS_DEBUG"
      [[ "$IS_DEBUG" = true ]] && echo "  Writing concat file "$concat_file" to "$in_dir""
      
      # Use glob to find all related WAV files
      for f in "$in_dir/${date}"_[0-9][0-9].{WAV,wav}; do
        if [[ -f "$f" ]]; then
          echo "file '$f'" >> "$file_to_write"
        fi
      done

      tmux new-window "ffmpeg -f concat -safe 0 -i \"$concat_file\" -c:a libmp3lame -ac 1 -q:a 15 \"$mp3_file\""
    fi
  done

  wait_for_ffmpeg_to_finish
}

clean_concat_file() {
  local clean_date=$(parse_date "$1")
  local out_dir="$2"

  local file_to_clean=$(concat_file "$clean_date" "$out_dir")
  mkdir -p "$(concat_dir "$out_dir")"
  [[ "$IS_DEBUG" = true ]] && echo "  Cleaning $file_to_clean in $(concat_dir "$out_dir")"

  rm -f "$file_to_clean"
  touch "$file_to_clean"
}

try_parse_filename_from_raw() {
  local raw_file="$1"
  local filename_no_ext="${raw_file##*/}"
  filename_no_ext="${filename_no_ext%%.*}"

  # Try to match YYYY_MM_DD_HH_MM_SS
  if [[ "$filename_no_ext" =~ ^([0-9]{4})_([0-9]{2})_([0-9]{2})_([0-9]{2})_([0-9]{2})_([0-9]{2})$ ]]; then
    echo "${BASH_REMATCH[1]}-${BASH_REMATCH[2]}-${BASH_REMATCH[3]}-${BASH_REMATCH[4]}${BASH_REMATCH[5]}"
  # Try to match YYYY-MM-DD-HHMM_NN
  elif [[ "$filename_no_ext" =~ ^([0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{4})(_[0-9]{2})?$ ]]; then
    echo "${BASH_REMATCH[1]}"
  else
    echo ""
  fi
}

calculate_default_prompt_value() {
  local last_duration="$1"
  local last_successful_filename_arg="$2"
  local raw_file="$3"
  local current_date_ym_arg="$4"

  local default_prompt_value=""
  local parsed_raw_filename=$(try_parse_filename_from_raw "$raw_file")

  if is_in_split_sequence "$last_duration" && [[ -n "$last_successful_filename_arg" ]]; then
    default_prompt_value="${last_successful_filename_arg%_*}"
  elif [[ -n "$parsed_raw_filename" ]]; then
    default_prompt_value="$parsed_raw_filename"
  else
    default_prompt_value="${current_date_ym_arg}"
  fi
  echo "$default_prompt_value"
}

get_next_increment() {
  local in_dir="$1"
  local base_name="$2"

  local i=0
  while true; do
    local suffix=$(printf "%02d" $i)
    local candidate="${base_name}_${suffix}"
    if [[ ! -f "$in_dir/${candidate}.WAV" && ! -f "$in_dir/${candidate}.wav" ]]; then
      echo "$candidate"
      return
    fi
    i=$((i + 1))
    if [[ $i -gt 99 ]]; then
      echo "${base_name}_99"
      return
    fi
  done
}

handle_user_input_and_file_action() {
  local new_file_name_input="$1"
  local original_file="$2"
  local in_dir="$3"
  local out_dir="$4"

  # Return codes:
  # 0: Action completed (break until loop)
  # 1: Error, continue until loop

  # Echoed output:
  # <new_last_successful_filename> (if rename)
  # "" (if delete or error where last_successful_filename should be cleared)

  if [[ "${new_file_name_input,,}" == "D" || "${new_file_name_input,,}" == "delete" || "${new_file_name_input}" =~ [Dd]$ ]]; then
    rm "$original_file"
    echo "Deleted '$original_file'" >&2
    echo ""
    return 0
  fi

  local base_name
  local final_name

  if [[ "$new_file_name_input" =~ ^([0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{4})(_[0-9]{2})?$ ]]; then
    base_name="${BASH_REMATCH[1]}"
    final_name=$(get_next_increment "$in_dir" "$base_name")

    mkdir -p "$out_dir"
    mv -n "$original_file" "$in_dir/$final_name.WAV"
    [[ "$IS_DEBUG" = true ]] && echo "Renamed '$original_file' to '$final_name.WAV'" >&2
    echo "$final_name"
    return 0
  else
    echo "ERROR: Invalid file name format. Please enter a valid name (yyyy-mm-dd-HHMM)." >&2
    echo ""
    return 1
  fi
}

name_audio_files() {
  local in_dir="$1"
  local out_dir="$2"
  local last_successful_filename=""
  local last_duration=""

  for file in "$in_dir"/*.@(WAV|wav); do
    if ! is_valid_file "$file"; then
      continue
    fi
    local new_file_name="$file"
    local has_file_moved=false

    until is_valid_file_name "$new_file_name"; do
      ffplay -nodisp -autoexit "$file" > /dev/null 2>&1 &
      local ffplay_process=$!
      sleep 0.1

      local file_size=$(du -h "$file" | awk '{print $1}')
      local current_duration=$(get_formatted_duration "$file")

      local current_date_ym=$(date "+%Y-%m-")

      local default_prompt_value=$(calculate_default_prompt_value \
        "$last_duration" \
        "$last_successful_filename" \
        "$file" \
        "$current_date_ym")

      echo "- [$file | $file_size | $current_duration]"
      read -p "[yyyy-mm-dd-HHMM]: " -i "$default_prompt_value" -e new_file_name
      kill "$ffplay_process" 2>/dev/null

      local returned_last_successful_filename
      returned_last_successful_filename=$(handle_user_input_and_file_action \
        "$new_file_name" \
        "$file" \
        "$in_dir" \
        "$out_dir")
      local action_exit_status=$?

      if [[ "$action_exit_status" == "0" ]]; then
        last_successful_filename="$returned_last_successful_filename"
        break
      fi
    done
    last_duration="$current_duration"
  done
}

ensure_valid_directories() {
  local in_dir="$1"
  local out_dir="$2"

  if [[ ! -d "$in_dir" || -z "$out_dir" ]]; then
    echo "Input and output directories expected."
    exit 1
  else
    if [[ "$IS_DEBUG" = true ]]; then
      echo "INPUT DIRECTORY: $in_dir"
      echo "OUTPUT DIRECTORY: $out_dir"
    fi
  fi
}

start_conversion() {
  local in_dir="$1"
  local out_dir="$2"

  ensure_valid_directories "$in_dir" "$out_dir"
  name_audio_files "$in_dir" "$out_dir"
  convert_audio_files "$in_dir" "$out_dir"
}

main() {
  local in_dir="$1"
  local out_dir="$2"
  local debugger="$3"

  if [[ "$debugger" = "debugger" ]]; then
    IS_DEBUG=true
    echo "DEBUGGER OUTPUT ENABLED"
  else
    IS_DEBUG=false
  fi

  start_conversion "$in_dir" "$out_dir"
  rm -rf "$(concat_dir "$out_dir")"
}

main "$@"

